{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git fetch:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(npm run:*)",
      "Edit(docs/**)",
      "Edit(src/**)"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [{"type": "command", "command": "npx block-no-verify@1.1.2"}]
      }
    ]
  }
}
